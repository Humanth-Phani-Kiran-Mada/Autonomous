# Environment variables for Self-Evolving AI System
# Copy this to .env and modify as needed

# Logging
LOG_LEVEL=INFO

# Crawler
CRAWLER_TIMEOUT=30
CRAWLER_MAX_WORKERS=5
CRAWLER_BATCH_SIZE=10

# Embedding model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Knowledge base
MAX_KNOWLEDGE=100000
MEMORY_COMPRESSION_RATIO=0.8

# Memory
MEMORY_RETENTION_DAYS=90
MEMORY_PERSISTENCE_INTERVAL=300

# Learning
LEARNING_RATE=0.01
EXPLORATION_RATE=0.2
IMPROVEMENT_THRESHOLD=0.05

# Task execution
MAX_TASK_RETRIES=3
TASK_TIMEOUT=300
PARALLEL_TASKS=3

# Self-improvement
SELF_IMPROVE_INTERVAL=3600
MAX_IMPROVEMENT_ITERATIONS=100
KNOWLEDGE_ACQUISITION_RATE=0.1

# Resource limits
MAX_MEMORY_MB=4096
MAX_CPU_PERCENT=80
RATE_LIMIT_PER_SECOND=10

# Autonomous mode
AUTONOMOUS_MODE=true
AUTO_START_LEARNING=true
AUTO_IMPROVE=true

# Performance tracking
ENABLE_PERF_TRACKING=true
METRICS_INTERVAL=60

# API Keys (if using external services)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
SERPER_API_KEY=
